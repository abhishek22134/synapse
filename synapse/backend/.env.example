# ── FREE AI (Groq) ─────────────────────────────────────
# https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_...

# ── FREE EMBEDDINGS (HuggingFace) ───────────────────────
# https://huggingface.co/settings/tokens → New token (read)
# Free tier: ~1000 requests/day — enough for dev + demos
HF_API_KEY=hf_...

# ── FREE VECTOR DB (Supabase) ───────────────────────────
# https://supabase.com → new project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ── GOOGLE DRIVE OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── SLACK OAuth ─────────────────────────────────────────
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ── APP ─────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
